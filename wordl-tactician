    // ── Scoring ───────────────────────────────────────────────────────────────
    function linguisticScore(word) {
        let w = 1.0;
        if (word.endsWith('s') && !validSingularS.has(word)) w *= 0.05;
        if (word.endsWith('ed')) w *= 0.10;
        if (/[qxjz]/.test(word)) w *= 0.45;
        const vowels = (word.match(/[aeiou]/g) || []).length;
        if (vowels >= 2 && vowels <= 3) w *= 2.5;
        return w;
    }

    function simulateFeedback(guess, target) {
        const status = [0,0,0,0,0];
        const targetUsed = [false,false,false,false,false];
        for (let i = 0; i < 5; i++) {
            if (guess[i] === target[i]) { status[i] = 2; targetUsed[i] = true; }
        }
        for (let i = 0; i < 5; i++) {
            if (status[i] === 2) continue;
            for (let j = 0; j < 5; j++) {
                if (!targetUsed[j] && guess[i] === target[j]) {
                    status[i] = 1; targetUsed[j] = true; break;
                }
            }
        }
        return status.join('');
    }

    // ── Calculate entropy for a candidate guess ───────────────────────────────
    function calcEntropy(guess, pool) {
        const buckets = {};
        for (const target of pool) {
            const key = simulateFeedback(guess, target);
            buckets[key] = (buckets[key] || 0) + 1;
        }
        let entropy = 0;
        const n = pool.length;
        for (const k in buckets) {
            const p = buckets[k] / n;
            entropy -= p * Math.log2(p);
        }
        return entropy;
    }

    // ── Rankings ──────────────────────────────────────────────────────────────
    function computeRankings() {
        const box = document.getElementById('rankings-box');

        if (remainingWords.length === 0) {
            box.innerHTML = "<div style='text-align:center;color:#e86060;font-size:0.8rem;padding:0.5rem;'>No valid matches found</div>";
            return;
        }

        // Opening moves (pre-computed best starters)
        if (remainingWords.length === masterWordList.length) {
            const openers = [
                {w:"salet", bits:"5.71", prob:"0.1%", probe:false},
                {w:"crate", bits:"5.68", prob:"3.4%", probe:false},
                {w:"trace", bits:"5.68", prob:"3.4%", probe:false},
                {w:"crane", bits:"5.67", prob:"2.9%", probe:false},
                {w:"slate", bits:"5.61", prob:"3.1%", probe:false},
            ];
            box.innerHTML = '';
            openers.forEach((item, i) => renderRankRow(box, i+1, item.w, item.bits, item.prob, false));
            return;
        }

        // Score remaining words by entropy
        const n = remainingWords.length;
        const scored = [];
        const sampleSize = Math.min(n, 500);
        const weightSum = remainingWords.reduce((s,w) => s + linguisticScore(w), 0);

        for (let i = 0; i < sampleSize; i++) {
            const guess = remainingWords[i];
            const entropy = calcEntropy(guess, remainingWords);
            const prob = weightSum > 0 ? (linguisticScore(guess) / weightSum * 100).toFixed(1) + "%" : "?";
            scored.push({w: guess, bits: entropy.toFixed(2) + " bits", prob, probe: false});
        }
        scored.sort((a, b) => parseFloat(b.bits) - parseFloat(a.bits));

        // In smart mode, if pool is large, also sample probe words from full list
        // to find words that split remaining pool more evenly (pure info plays)
        const candidates = scored.slice(0, 5);

        if (mode === 'smart' && n > 6) {
            // Sample a broader candidate set
            const probeSet = [];
            const step = Math.max(1, Math.floor(masterWordList.length / 300));
            for (let i = 0; i < masterWordList.length; i += step) {
                const guess = masterWordList[i];
                if (remainingWords.includes(guess)) continue; // already scored
                const entropy = calcEntropy(guess, remainingWords);
                probeSet.push({w: guess, bits: entropy.toFixed(2) + " bits", prob: "—", probe: true});
            }
            probeSet.sort((a, b) => parseFloat(b.bits) - parseFloat(a.bits));

            // Merge: if best probe beats top valid word significantly, include it
            if (probeSet.length > 0) {
                const bestValid = parseFloat(scored[0]?.bits || 0);
                const bestProbe = parseFloat(probeSet[0]?.bits || 0);
                if (bestProbe > bestValid + 0.15) {
                    candidates.unshift({...probeSet[0], isTopProbe: true});
                    if (candidates.length > 5) candidates.pop();
                }
            }
        }

        box.innerHTML = '';
        candidates.forEach((item, i) => renderRankRow(box, i+1, item.w, item.bits, item.prob, item.probe));
    }

    function renderRankRow(parent, rank, word, bits, prob, isProbe) {
        const probVal = parseFloat(prob);
        const isLowProb = !isNaN(probVal) && probVal < 0.5;
        const row = document.createElement('div');
        row.className = 'rank-row';
        row.onclick = () => autoFill(word);

        const wordClass = isProbe ? 'rank-word probe' : (isLowProb ? 'rank-word dimmed' : 'rank-word');
        const probClass = isLowProb ? 'rank-prob low' : 'rank-prob';
        const badge = isProbe ? `<span class="probe-badge">probe</span>` : '';

        row.innerHTML = `
            <div style="display:flex;align-items:center;">
                <span class="rank-num">${rank}</span>
                <span class="${wordClass}">${word}</span>${badge}
            </div>
            <div class="rank-meta">
                <span class="rank-bits">${bits}</span>
                <span class="${probClass}">${prob}</span>
            </div>
        `;
        parent.appendChild(row);
    }

    // ── Display update ────────────────────────────────────────────────────────
    function updateDisplay() {
        // Word count
        const wc = document.getElementById('word-count');
        wc.textContent = remainingWords.length;
        wc.className = 'stat-value' + (remainingWords.length <= 2 ? ' urgent' : remainingWords.length <= 6 ? '' : ' safe');

        // Word pool
        const pool = document.getElementById('word-list');
        pool.innerHTML = '';
        if (remainingWords.length === 0) {
            pool.innerHTML = "<span style='color:#e86060;font-size:0.8rem;font-style:italic;'>No valid words remain.</span>";
        } else {
            remainingWords.slice(0, 60).forEach(word => {
                const chip = document.createElement('span');
                chip.className = 'word-chip' + (linguisticScore(word) < 0.2 ? ' unlikely' : '');
                chip.textContent = word;
                chip.onclick = () => autoFill(word);
                pool.appendChild(chip);
            });
            if (remainingWords.length > 60) {
                const more = document.createElement('span');
                more.style.cssText = 'font-size:0.65rem;color:var(--gray);align-self:center;';
                more.textContent = `+${remainingWords.length - 60} more`;
                pool.appendChild(more);
            }
        }

        computeRankings();
        updateKnownLetters();
    }

    function updateKnownLetters() {
        const knownCard = document.getElementById('known-card');
        const container = document.getElementById('known-letters');
        if (guessHistory.length === 0) { knownCard.style.display = 'none'; return; }

        const green = {}; // pos -> letter
        const yellow = new Set();
        const gray = new Set();
        const greenLetters = new Set();

        for (const {guess, feedback} of guessHistory) {
            for (let i = 0; i < 5; i++) {
                const l = guess[i];
                if (feedback[i] === 2) { green[i] = l; greenLetters.add(l); }
                else if (feedback[i] === 1) yellow.add(l);
                else if (feedback[i] === 0) {
                    // Only mark gray if not also green/yellow
                    const isElsewhere = guessHistory.some(({guess:g, feedback:f}) =>
                        g.split('').some((c, j) => c === l && f[j] > 0));
                    if (!isElsewhere) gray.add(l);
                }
            }
        }

        container.innerHTML = '';
        // Greens (fixed positions)
        for (const [pos, letter] of Object.entries(green)) {
            const span = document.createElement('span');
            span.className = 'known-letter green';
            span.textContent = `${letter.toUpperCase()}${+pos+1}`;
            span.title = `${letter.toUpperCase()} is correct in position ${+pos+1}`;
            container.appendChild(span);
        }
        // Yellows
        for (const l of yellow) {
            if (greenLetters.has(l)) continue;
            const span = document.createElement('span');
            span.className = 'known-letter yellow';
            span.textContent = l.toUpperCase();
            span.title = `${l.toUpperCase()} is in the word but wrong position`;
            container.appendChild(span);
        }
        // Grays
        for (const l of gray) {
            const span = document.createElement('span');
            span.className = 'known-letter gray';
            span.textContent = l.toUpperCase();
            container.appendChild(span);
        }

        knownCard.style.display = guessHistory.length > 0 ? '' : 'none';
    }

    function updateHistory() {
        const grid = document.getElementById('history-grid');
        if (guessHistory.length === 0) {
            grid.innerHTML = "<span class='history-empty'>No guesses yet — start playing!</span>";
            return;
        }
        grid.innerHTML = '';
        guessHistory.forEach(({guess, feedback}, idx) => {
            const row = document.createElement('div');
            row.className = 'history-row';
            const num = document.createElement('span');
            num.className = 'history-turn';
            num.textContent = idx + 1;
            row.appendChild(num);
            for (let i = 0; i < 5; i++) {
                const tile = document.createElement('div');
                tile.className = `history-tile s${feedback[i]}`;
                tile.textContent = guess[i].toUpperCase();
                row.appendChild(tile);
            }
            grid.appendChild(row);
        });
    }

    // ── Input ─────────────────────────────────────────────────────────────────
    function setupInputs() {
        for (let i = 0; i < 5; i++) {
            const inp = document.getElementById(`c${i}`);

            inp.addEventListener('input', () => {
                const val = inp.value.replace(/[^a-zA-Z]/g,'');
                inp.value = val ? val[val.length-1].toUpperCase() : '';
                if (inp.value && i < 4) document.getElementById(`c${i+1}`).focus();
            });

            inp.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace') {
                    if (inp.value) { inp.value = ''; }
                    else if (i > 0) {
                        e.preventDefault();
                        const prev = document.getElementById(`c${i-1}`);
                        prev.value = '';
                        prev.focus();
                    }
                }
                if (e.key === 'Enter') submitTurn();
            });

            inp.addEventListener('focus', () => inp.select());
        }

        // Global enter key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && document.activeElement.tagName !== 'BUTTON') submitTurn();
        });
    }

    function autoFill(word) {
        for (let i = 0; i < 5; i++) {
            document.getElementById(`c${i}`).value = word[i].toUpperCase();
        }
        document.getElementById('b0').focus();
    }

    function toggleColor(index) {
        tileStates[index] = (tileStates[index] + 1) % 3;
        const s = tileStates[index];
        const labels = ['Gray','Yellow','Green'];
        const btn = document.getElementById(`b${index}`);
        const inp = document.getElementById(`c${index}`);
        btn.className = `color-btn s${s}`;
        btn.textContent = labels[s];
        inp.className = 'tile-input' + (s > 0 ? ` s${s}` : '');
    }

    // ── Filter ────────────────────────────────────────────────────────────────
    function filterWords(guess, feedback) {
        // Pre-compute per-letter constraints from this guess.
        // For each unique letter, determine:
        //   minCount: how many must appear in the answer (green + yellow hits)
        //   exact:    if a gray appeared with no green/yellow, the answer has exactly minCount of it
        //   greens:   which positions are locked
        //   notAt:    which positions it must NOT be (yellow positions)
        const constraints = {};
        for (let i = 0; i < 5; i++) {
            const l = guess[i];
            if (!constraints[l]) constraints[l] = { minCount: 0, exact: false, greens: [], notAt: [] };
            const c = constraints[l];
            if (feedback[i] === 2) { c.minCount++; c.greens.push(i); }
            else if (feedback[i] === 1) { c.minCount++; c.notAt.push(i); }
            else { c.exact = true; } // gray → word has exactly minCount of this letter
        }

        return remainingWords.filter(word => {
            for (const [letter, c] of Object.entries(constraints)) {
                const count = (word.match(new RegExp(letter, 'g')) || []).length;
                // Must have at least minCount occurrences
                if (count < c.minCount) return false;
                // If gray also appeared, must have exactly minCount (no extras)
                if (c.exact && count !== c.minCount) return false;
                // Green positions must match
                for (const pos of c.greens) { if (word[pos] !== letter) return false; }
                // Yellow positions must NOT be that letter there
                for (const pos of c.notAt) { if (word[pos] === letter) return false; }
            }
            return true;
        });
    }

    // ── Submit ────────────────────────────────────────────────────────────────
    function submitTurn() {
        if (gameOver) return;

        let guess = '';
        const feedback = [...tileStates];

        for (let i = 0; i < 5; i++) {
            const ch = document.getElementById(`c${i}`).value.toLowerCase();
            if (!ch || !/[a-z]/.test(ch)) {
                setStatus('Fill in all 5 letters first.', 'warn');
                document.getElementById(`c${i}`).focus();
                return;
            }
            guess += ch;
        }

        // Check win
        const isWin = feedback.every(s => s === 2);

        guessHistory.push({guess, feedback: [...feedback]});
        remainingWords = filterWords(guess, feedback);

        updateHistory();
        updateDisplay();
        clearInputRow();

        if (isWin) {
            setStatus(`Solved in ${guessHistory.length} guess${guessHistory.length > 1 ? 'es' : ''}! 🎉`, 'win');
            gameOver = true;
            return;
        }

        if (remainingWords.length === 0) {
            setStatus('No valid words remain — check your color inputs.', 'err');
            return;
        }

        if (remainingWords.length === 1) {
            setStatus(`Only one word left: ${remainingWords[0].toUpperCase()} — play it!`, 'win');
            return;
        }

        const count = remainingWords.length;
        setStatus(`${count} word${count !== 1 ? 's' : ''} remaining after guess ${guessHistory.length}`, '');
    }

    function setStatus(msg, type) {
        const bar = document.getElementById('status-bar');
        bar.textContent = msg;
        bar.className = 'status-bar' + (type ? ' ' + type : '');
    }

    function clearInputRow() {
        for (let i = 0; i < 5; i++) {
            document.getElementById(`c${i}`).value = '';
            document.getElementById(`c${i}`).className = 'tile-input';
            document.getElementById(`b${i}`).className = 'color-btn s0';
            document.getElementById(`b${i}`).textContent = 'Gray';
        }
        tileStates = [0, 0, 0, 0, 0];
        document.getElementById('c0').focus();
    }

    function setMode(m) {
        mode = m;
        document.getElementById('mode-smart').className = 'mode-btn' + (m === 'smart' ? ' active' : '');
        document.getElementById('mode-strict').className = 'mode-btn' + (m === 'strict' ? ' active' : '');
        computeRankings();
    }

    function resetGame() {
        remainingWords = [...masterWordList];
        guessHistory = [];
        gameOver = false;
        clearInputRow();
        updateHistory();
        updateDisplay();
        setStatus('Game reset — enter your first guess', '');
    }

    // ── Init ──────────────────────────────────────────────────────────────────
    setupInputs();
    fetchWordList();
    document.getElementById('c0').focus();
</script>
</body>
</html>
