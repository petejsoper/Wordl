<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wordle Tactician</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f1117;
            --surface: #181c27;
            --surface2: #1f2435;
            --border: #2a3050;
            --gray: #6b7794;
            --gray-tile: #3a4060;
            --yellow: #c9a227;
            --yellow-bg: #2a2206;
            --green: #3cb371;
            --green-bg: #0a2218;
            --purple: #7c6af7;
            --purple-dim: #3d3580;
            --pink: #e879a0;
            --text: #e8eaf6;
            --text-dim: #8892b0;
            --font-ui: 'Space Grotesk', sans-serif;
            --font-mono: 'Space Mono', monospace;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-ui);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem 1rem 4rem;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            background: linear-gradient(135deg, var(--purple), var(--pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .header p {
            color: var(--text-dim);
            font-size: 0.8rem;
            margin-top: 0.3rem;
            letter-spacing: 0.05em;
        }

        .app {
            width: 100%;
            max-width: 480px;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        /* Card */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.25rem;
        }
        .card-title {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--text-dim);
            margin-bottom: 1rem;
        }

        /* Guess History */
        .history-grid {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            min-height: 2.5rem;
        }
        .history-row {
            display: flex;
            gap: 0.4rem;
            align-items: center;
        }
        .history-turn {
            font-size: 0.65rem;
            color: var(--text-dim);
            font-family: var(--font-mono);
            width: 1.2rem;
            text-align: right;
            flex-shrink: 0;
        }
        .history-tile {
            width: 2.2rem;
            height: 2.2rem;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 0.95rem;
            text-transform: uppercase;
            border: 1px solid transparent;
        }
        .history-tile.s0 { background: var(--gray-tile); color: var(--text-dim); }
        .history-tile.s1 { background: var(--yellow-bg); border-color: var(--yellow); color: var(--yellow); }
        .history-tile.s2 { background: var(--green-bg); border-color: var(--green); color: var(--green); }
        .history-empty { color: var(--text-dim); font-size: 0.8rem; font-style: italic; }

        /* Input Row */
        .input-tiles {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            margin-bottom: 0.75rem;
        }
        .tile-input {
            width: 3.2rem;
            height: 3.2rem;
            border-radius: 10px;
            background: var(--surface2);
            border: 2px solid var(--border);
            color: var(--text);
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 1.4rem;
            text-align: center;
            text-transform: uppercase;
            outline: none;
            transition: border-color 0.15s, background 0.15s;
        }
        .tile-input:focus { border-color: var(--purple); }
        .tile-input.s1 { background: var(--yellow-bg); border-color: var(--yellow); color: var(--yellow); }
        .tile-input.s2 { background: var(--green-bg); border-color: var(--green); color: var(--green); }

        /* Color buttons */
        .color-buttons {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            margin-bottom: 1rem;
        }
        .color-btn {
            flex: 1;
            height: 2.2rem;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--surface2);
            color: var(--text-dim);
            font-family: var(--font-ui);
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            cursor: pointer;
            transition: all 0.15s;
        }
        .color-btn.s0 { background: var(--gray-tile); color: #aaa; border-color: transparent; }
        .color-btn.s1 { background: var(--yellow-bg); color: var(--yellow); border-color: var(--yellow); }
        .color-btn.s2 { background: var(--green-bg); color: var(--green); border-color: var(--green); }

        /* Action buttons */
        .actions { display: flex; gap: 0.6rem; }
        .btn-primary {
            flex: 1;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            border: none;
            background: linear-gradient(135deg, var(--purple-dim), #5a2060);
            color: var(--text);
            font-family: var(--font-ui);
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: opacity 0.15s, transform 0.1s;
            letter-spacing: 0.03em;
        }
        .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }
        .btn-secondary {
            padding: 0.75rem 1rem;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--surface2);
            color: var(--text-dim);
            font-family: var(--font-ui);
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: background 0.15s;
        }
        .btn-secondary:hover { background: var(--border); }

        /* Mode toggle */
        .mode-row {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 0.75rem;
        }
        .mode-btn {
            flex: 1;
            padding: 0.45rem;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--surface2);
            color: var(--text-dim);
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            cursor: pointer;
            transition: all 0.15s;
        }
        .mode-btn.active {
            background: var(--purple-dim);
            border-color: var(--purple);
            color: #d0c8ff;
        }

        /* Rankings */
        .rank-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--gray);
            padding-bottom: 0.6rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 0.6rem;
        }
        .rank-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.6rem 0.75rem;
            border-radius: 8px;
            background: var(--surface2);
            border: 1px solid transparent;
            cursor: pointer;
            transition: all 0.15s;
            margin-bottom: 0.4rem;
        }
        .rank-row:hover { border-color: var(--purple-dim); background: #1a1e30; }
        .rank-row:last-child { margin-bottom: 0; }
        .rank-num { font-size: 0.7rem; color: var(--gray); width: 1.2rem; font-family: var(--font-mono); }
        .rank-word {
            font-family: var(--font-mono);
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--purple);
            flex: 1;
            padding-left: 0.6rem;
        }
        .rank-word.dimmed { color: var(--gray); text-decoration: line-through; opacity: 0.4; }
        .rank-word.probe { color: var(--pink); }
        .rank-meta { display: flex; gap: 1.25rem; align-items: center; }
        .rank-bits { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); }
        .rank-prob { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; color: var(--pink); min-width: 3rem; text-align: right; }
        .rank-prob.low { color: var(--gray); font-weight: 400; }
        .probe-badge {
            font-size: 0.55rem;
            padding: 0.1rem 0.35rem;
            border-radius: 4px;
            background: #3a1030;
            color: var(--pink);
            border: 1px solid #6a2050;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-left: 0.4rem;
        }

        /* Stat row */
        .stat-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }
        .stat-label { font-size: 0.75rem; color: var(--text-dim); }
        .stat-value {
            font-family: var(--font-mono);
            font-weight: 700;
            color: var(--purple);
            font-size: 0.85rem;
            background: var(--surface2);
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
        }
        .stat-value.urgent { color: var(--pink); }
        .stat-value.safe { color: var(--green); }

        /* Word list */
        .word-pool {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0.75rem;
            max-height: 8rem;
            overflow-y: auto;
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
        }
        .word-chip {
            font-family: var(--font-mono);
            font-size: 0.7rem;
            text-transform: uppercase;
            padding: 0.2rem 0.5rem;
            border-radius: 5px;
            background: #1e2438;
            border: 1px solid var(--border);
            color: var(--text-dim);
            cursor: pointer;
            transition: all 0.12s;
        }
        .word-chip:hover { border-color: var(--purple); color: var(--purple); }
        .word-chip.unlikely { opacity: 0.25; text-decoration: line-through; color: #e86060; border-color: #4a1515; }

        /* Alert / status */
        .status-bar {
            font-size: 0.75rem;
            text-align: center;
            color: var(--text-dim);
            padding: 0.5rem;
            border-radius: 8px;
            background: var(--surface2);
            border: 1px solid var(--border);
        }
        .status-bar.win { color: var(--green); background: var(--green-bg); border-color: var(--green); font-weight: 700; }
        .status-bar.warn { color: var(--yellow); background: var(--yellow-bg); border-color: var(--yellow); }
        .status-bar.err { color: #e86060; background: #2a0a0a; border-color: #6a1515; }

        /* Known letters display */
        .known-letters {
            display: flex;
            gap: 0.4rem;
            flex-wrap: wrap;
        }
        .known-letter {
            font-family: var(--font-mono);
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 0.2rem 0.5rem;
            border-radius: 5px;
        }
        .known-letter.green { background: var(--green-bg); color: var(--green); border: 1px solid var(--green); }
        .known-letter.yellow { background: var(--yellow-bg); color: var(--yellow); border: 1px solid var(--yellow); }
        .known-letter.gray { background: var(--gray-tile); color: var(--text-dim); border: 1px solid transparent; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

        /* Loading */
        .loading-dots::after {
            content: '';
            animation: dots 1.2s steps(3, end) infinite;
        }
        @keyframes dots {
            0%   { content: '.'; }
            33%  { content: '..'; }
            66%  { content: '...'; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Wordle Tactician</h1>
        <p>Entropy-guided solver · 3-guess target</p>
    </div>

    <div class="app">
        <!-- Status -->
        <div id="status-bar" class="status-bar loading-dots">Loading word list</div>

        <!-- Rankings -->
        <div class="card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.6rem;">
                <div class="card-title" style="margin-bottom:0">Top Suggestions</div>
                <div class="mode-row" style="margin-bottom:0; gap:0.35rem;">
                    <button class="mode-btn active" id="mode-smart" onclick="setMode('smart')" title="Show best guesses from full word list when needed">Smart</button>
                    <button class="mode-btn" id="mode-strict" onclick="setMode('strict')" title="Only guess remaining valid words">Strict</button>
                </div>
            </div>
            <div class="rank-header">
                <span>Rank · Word</span>
                <div style="display:flex; gap:1.25rem; padding-right:0.2rem;">
                    <span>Entropy</span>
                    <span style="min-width:3rem; text-align:right;">Prob</span>
                </div>
            </div>
            <div id="rankings-box">
                <div style="text-align:center; color:var(--text-dim); font-size:0.8rem; padding:0.5rem;">Calculating<span class="loading-dots"></span></div>
            </div>
            <p style="font-size:0.65rem; color:var(--gray); text-align:center; margin-top:0.5rem;">
                <span style="color:var(--pink);">Pink</span> = probe from full list ·
                <span style="color:var(--purple);">Purple</span> = valid answer ·
                Click any word to fill it in
            </p>
        </div>

        <!-- Input -->
        <div class="card">
            <div class="card-title">Enter Your Guess + Result</div>

            <div class="input-tiles">
                <input type="text" maxlength="1" id="c0" class="tile-input" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false">
                <input type="text" maxlength="1" id="c1" class="tile-input" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false">
                <input type="text" maxlength="1" id="c2" class="tile-input" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false">
                <input type="text" maxlength="1" id="c3" class="tile-input" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false">
                <input type="text" maxlength="1" id="c4" class="tile-input" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false">
            </div>

            <div class="color-buttons">
                <button class="color-btn s0" id="b0" onclick="toggleColor(0)" type="button">Gray</button>
                <button class="color-btn s0" id="b1" onclick="toggleColor(1)" type="button">Gray</button>
                <button class="color-btn s0" id="b2" onclick="toggleColor(2)" type="button">Gray</button>
                <button class="color-btn s0" id="b3" onclick="toggleColor(3)" type="button">Gray</button>
                <button class="color-btn s0" id="b4" onclick="toggleColor(4)" type="button">Gray</button>
            </div>

            <div class="actions">
                <button class="btn-primary" onclick="submitTurn()" type="button">Submit Guess (Enter ↵)</button>
                <button class="btn-secondary" onclick="resetGame()" type="button">Reset</button>
            </div>
        </div>

        <!-- Known letters key -->
        <div class="card" id="known-card" style="display:none;">
            <div class="card-title">Deduced Letter State</div>
            <div id="known-letters" class="known-letters"></div>
        </div>

        <!-- Guess history -->
        <div class="card" id="history-card">
            <div class="card-title">Guess History</div>
            <div id="history-grid" class="history-grid">
                <span class="history-empty">No guesses yet — start playing!</span>
            </div>
        </div>

        <!-- Remaining words -->
        <div class="card">
            <div class="stat-row">
                <span class="stat-label">Valid Answers Remaining</span>
                <span class="stat-value" id="word-count">—</span>
            </div>
            <div class="word-pool" id="word-list"></div>
        </div>
    </div>

<script>
    // ── State ─────────────────────────────────────────────────────────────────
    let masterWordList = [];
    let remainingWords = [];
    let tileStates = [0, 0, 0, 0, 0];
    let guessHistory = [];
    let mode = 'smart'; // 'smart' | 'strict'
    let gameOver = false;

    // Words that naturally end in S/ED and are valid answers
    const validSingularS = new Set(["bonus","glass","class","grass","dress","cross","bliss","abyss","focus","fetus","mucus","virus","locus","truss","brass","crass","dwarf","farce","fjord","gnats","grabs","grads","grams","imams","knobs","lamps","leans","loans","moans","oaths","racks","rails","rains","ramps","reams","risks","roads","roams","roans","ruins","rumps","seams","shams","skims","slams","slaps","slats","slops","slums","snaps","soaks","soaps","spans","spars","spats","specs","spots","stabs","slews"]);

    // ── Fetch word list ───────────────────────────────────────────────────────
